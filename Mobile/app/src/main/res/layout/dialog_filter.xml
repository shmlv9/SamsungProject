<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="#FF1A1A1A"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выберите фильтр"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:id="@+id/optionNone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="8dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Нет"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="4dp" />

    <LinearLayout
        android:id="@+id/optionCold"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="8dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#4488FF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Холодный"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="4dp" />

    <LinearLayout
        android:id="@+id/optionWarm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="8dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#FF8800" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Тёплый"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="4dp" />

    <LinearLayout
        android:id="@+id/optionEffect"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="8dp">

        <View
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#FF3366" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Эффектный"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

</LinearLayout>
